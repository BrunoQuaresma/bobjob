<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>Resume{{#if name}} - {{name}}{{/if}}</title>
    <style>
      __GEIST_FONT_FACES__
      :root {
        /* Colors */
        --text-base-color: #334155;
        --text-headline-color: #020617;
        --text-muted-color: #64748b;

        /* Spacing (base unit 4px, multiples of 4) */
        --spacing: 0.25rem;
        --spacing-sm: calc(var(--spacing) * 2);
        --spacing-md: calc(var(--spacing) * 3);
        --spacing-lg: calc(var(--spacing) * 4);
        --spacing-xl: calc(var(--spacing) * 6);

        /* Typography - font sizes */
        --text-sm: 8pt;
        --text-md: 9pt;
        --text-lg: 10pt;
        --text-xl: 20pt;

        /* Typography - font weights */
        --font-regular: 400;
        --font-medium: 500;
        --font-bold: 600;

        /* Typography - line heights (TailwindCSS scale) */
        --leading-none: 1;
        --leading-tight: 1.25;
        --leading-snug: 1.375;
        --leading-normal: 1.5;
        --leading-relaxed: 1.625;
        --leading-loose: 2;

        /* Layout */
        --resume-font-family: 'Geist', system-ui, sans-serif;
        --resume-letter-spacing-name: -0.02em;
        --resume-letter-spacing-section: 0.08em;
        --resume-page-margin: 1.5cm;
        --resume-sidebar-width: 33.333%;
      }
      @page {
        size: A4;
        margin: var(--resume-page-margin);
      }
      @media print {
        body {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }
      }
      * {
        box-sizing: border-box;
      }
      body {
        font-family: var(--resume-font-family);
        font-size: var(--text-md);
        line-height: var(--leading-normal);
        color: var(--text-base-color);
        margin: 0;
        padding: 0;
      }
      .resume-header {
        margin-bottom: calc(var(--spacing) * 8);
      }
      .resume-name {
        font-size: var(--text-xl);
        font-weight: var(--font-bold);
        color: var(--text-headline-color);
        margin: 0 0 0.05em 0;
        letter-spacing: var(--resume-letter-spacing-name);
      }
      .resume-title {
        font-size: var(--text-lg);
        font-weight: var(--font-regular);
        color: var(--text-muted-color);
        margin: 0;
      }
      .contact-item {
        margin-bottom: 0.25em;
      }
      .contact-item:last-child {
        margin-bottom: 0;
      }
      .contact-item a {
        color: var(--text-base-color);
        text-decoration: none;
      }
      .main-body {
        display: flex;
        gap: var(--spacing-xl);
      }
      .sidebar {
        width: var(--resume-sidebar-width);
        flex-shrink: 0;
        padding-right: var(--spacing-lg);
      }
      .main-content {
        flex: 1;
        min-width: 0;
      }
      .section {
        margin-bottom: var(--spacing-xl);
      }
      .section:last-child {
        margin-bottom: 0;
      }
      .section-title {
        font-size: var(--text-md);
        font-weight: var(--font-bold);
        text-transform: uppercase;
        letter-spacing: var(--resume-letter-spacing-section);
        color: var(--text-headline-color);
        margin: 0 0 var(--spacing-sm) 0;
        padding-bottom: var(--spacing);
      }
      .summary-text {
        line-height: var(--leading-relaxed);
        margin: 0;
      }
      .education-item,
      .certificate-item {
        margin-bottom: var(--spacing-md);
      }
      .education-item:last-child,
      .certificate-item:last-child {
        margin-bottom: 0;
      }
      .item-degree,
      .item-cert-name {
        font-weight: var(--font-medium);
        color: var(--text-headline-color);
      }
      .item-date {
        font-size: var(--text-sm);
        color: var(--text-muted-color);
      }
      .skills-list {
        margin: 0;
        padding-left: var(--spacing-lg);
      }
      .skills-list li {
        margin-bottom: 0.2em;
      }
      .experience-item,
      .project-item {
        margin-bottom: var(--spacing-xl);
      }
      .experience-item:last-child,
      .project-item:last-child {
        margin-bottom: 0;
      }
      .exp-heading {
        margin-bottom: var(--spacing-md);
      }
      .exp-title,
      .project-name {
        font-weight: var(--font-medium);
        font-size: var(--text-lg);
        color: var(--text-headline-color);
      }
      .project-name a {
        color: inherit;
        text-decoration: none;
      }
      .exp-meta,
      .project-meta {
        font-size: var(--text-sm);
        margin-top: 0.15em;
        color: var(--text-muted-color);
      }
      .item-description {
        margin-top: var(--spacing-sm);
      }
      .highlights {
        margin: var(--spacing-sm) 0 0 0;
        padding-left: var(--spacing-lg);
      }
      .highlights li {
        margin-bottom: 0.15em;
      }
    </style>
  </head>
  <body>
    <header class='resume-header'>
      {{#if name}}<h1 class='resume-name'>{{name}}</h1>{{/if}}
      {{#if title}}<p class='resume-title'>{{title}}</p>{{/if}}
    </header>

    <div class='main-body'>
      <aside class='sidebar'>
        {{#if (hasContactInfo this)}}
          <section class='section'>
            <h2 class='section-title'>Contact</h2>
            {{#if contact}}
              {{#if contact.email}}
                <div class='contact-item'>
                  <a href='mailto:{{contact.email}}'>{{contact.email}}</a>
                </div>
              {{/if}}
              {{#if contact.phone}}
                <div class='contact-item'>{{contact.phone}}</div>
              {{/if}}
            {{/if}}
            {{#if location}}
              <div class='contact-item'>{{location}}</div>
            {{/if}}
            {{#if socials}}
              {{#if socials.linkedin}}
                <div class='contact-item'>
                  <a href='{{socials.linkedin}}'>LinkedIn</a>
                </div>
              {{/if}}
              {{#if socials.github}}
                <div class='contact-item'>
                  <a href='{{socials.github}}'>GitHub</a>
                </div>
              {{/if}}
              {{#if socials.portfolio}}
                <div class='contact-item'>
                  <a href='{{socials.portfolio}}'>Portfolio</a>
                </div>
              {{/if}}
            {{/if}}
          </section>
        {{/if}}

        {{#if (hasItems education)}}
          <section class='section'>
            <h2 class='section-title'>Education</h2>
            {{#each education}}
              <div class='education-item'>
                <div class='item-degree'>{{degree}}{{#if field}} in {{field}}{{/if}}</div>
                <div class='item-school'>{{school}}</div>
                <div class='item-date'>{{formatDate startDate}} – {{formatDate endDate}}</div>
              </div>
            {{/each}}
          </section>
        {{/if}}

        {{#if (hasItems certificates)}}
          <section class='section'>
            <h2 class='section-title'>Certificates</h2>
            {{#each certificates}}
              <div class='certificate-item'>
                <div class='item-cert-name'>{{name}}</div>
                <div class='item-cert-issuer'>{{issuer}}</div>
                {{#if date}}<div class='item-date'>{{formatDate date}}</div>{{/if}}
              </div>
            {{/each}}
          </section>
        {{/if}}

        {{#if (hasItems skills)}}
          <section class='section'>
            <h2 class='section-title'>Skills</h2>
            <ul class='skills-list'>
              {{#each skills}}<li>{{this}}</li>{{/each}}
            </ul>
          </section>
        {{/if}}
      </aside>

      <main class='main-content'>
        {{#if summary}}
          <section class='section'>
            <h2 class='section-title'>Profile</h2>
            <p class='summary-text'>{{summary}}</p>
          </section>
        {{/if}}

        {{#if (hasItems experiences)}}
          <section class='section'>
            <h2 class='section-title'>Experience</h2>
            {{#each experiences}}
              <div class='experience-item'>
                <div class='exp-heading'>
                  <div class='exp-title'>{{title}}{{#if company}} at {{company}}{{/if}}</div>
                  <div class='exp-meta'>
                    {{#if location}}{{location}}{{#if startDate}} · {{/if}}{{/if}}
                    {{#if startDate}}{{formatDate startDate}}{{/if}}
                    {{#if endDate}} – {{formatDate endDate}}{{else}}{{#if startDate}} – Present{{/if}}{{/if}}
                  </div>
                </div>
                {{#if description}}<div class='item-description'>{{description}}</div>{{/if}}
                {{#if highlights}}
                  <ul class='highlights'>
                    {{#each highlights}}<li>{{this}}</li>{{/each}}
                  </ul>
                {{/if}}
              </div>
            {{/each}}
          </section>
        {{/if}}

        {{#if (hasItems projects)}}
          <section class='section'>
            <h2 class='section-title'>Projects</h2>
            {{#each projects}}
              <div class='project-item'>
                <div class='project-name'>{{#if url}}<a href='{{url}}'>{{name}}</a>{{else}}{{name}}{{/if}}</div>
                {{#if description}}<div class='item-description'>{{description}}</div>{{/if}}
                {{#if highlights}}
                  <ul class='highlights'>
                    {{#each highlights}}<li>{{this}}</li>{{/each}}
                  </ul>
                {{/if}}
              </div>
            {{/each}}
          </section>
        {{/if}}
      </main>
    </div>
  </body>
</html>
