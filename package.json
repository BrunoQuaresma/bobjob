{
  "name": "bobjob",
  "type": "module",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrunoQuaresma/bobjob.git"
  },
  "homepage": "https://github.com/BrunoQuaresma/bobjob#readme",
  "bugs": {
    "url": "https://github.com/BrunoQuaresma/bobjob/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@bobjob/core": "workspace:*"
  },
  "scripts": {
    "bobjob": "bun run --cwd packages/cli start",
    "refine": "bun run --cwd packages/cli src/index.ts refine",
    "resume": "bun run --cwd packages/cli resume",
    "generate-test-resume": "bun run scripts/generate-test-resume.ts",
    "core:test": "bun run --cwd packages/core test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run core:test && bun run cli:test",
    "cli:test": "bun run --cwd packages/cli test"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
