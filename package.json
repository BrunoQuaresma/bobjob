{
  "name": "bobjob",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bobjob": "bun run --filter @bobjob/cli start",
    "resume": "bun run --filter @bobjob/cli resume",
    "core:test": "bun run --filter @bobjob/core test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run core:test"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
